# ACDSS environment configuration (TEMPLATE — placeholders only, no real secrets)
# Copy to `.env` and fill in. `.env` is git-ignored.

# ---- LLM provider ----------------------------------------------------------
# Provider-agnostic. Default implementation targets the Anthropic API.
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_NAME=claude-sonnet-5
LLM_MAX_TOKENS=4096
# Adaptive thinking: on | off  (recommended: on for reasoning-heavy agents)
LLM_THINKING=on

# ---- Vector store / database ----------------------------------------------
# Postgres connection string used for both the pgvector store and MIMIC-IV.
DB_URL=postgresql://acdss:changeme@localhost:5432/acdss
VECTOR_DB=pgvector
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ---- MIMIC-IV --------------------------------------------------------------
# Schema/prefix of the MIMIC-IV tables inside the Postgres instance.
MIMIC_SCHEMA=mimiciv
# Path to a local guidelines corpus to ingest into the vector store.
GUIDELINES_PATH=./data/guidelines

# ---- API -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Require human-in-the-loop sign-off before returning a recommendation.
REQUIRE_HITL=true

# ---- Trust / safety --------------------------------------------------------
AUDIT_LOG_PATH=./logs/audit.jsonl
# Minimum aggregate confidence below which the system abstains.
MIN_CONFIDENCE=0.6

# ---- Misc ------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
